META_ACCESS_TOKEN=YOUR_MLB_META_ACCESS_TOKEN
META_AD_ACCOUNT_ID=act_YOUR_MLB_AD_ACCOUNT_ID
META_API_VERSION=v19.0

# Snowflake 접속 정보
SNOWFLAKE_ACCOUNT=your_account.region          # 예: abc12345.ap-northeast-1
SNOWFLAKE_USER=your_service_account_id
# 방법1 (권장): .p8 파일 경로 지정 (파일은 절대 Git 커밋 금지)
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# 방법2: .p8 파일 내용을 한 줄로 (줄바꿈을 \n으로 치환)
# SNOWFLAKE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_ROLE=PU_PF
SNOWFLAKE_TABLE=META_AD_SNAPSHOT

# Gemini AI 설정
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# 이메일 Alert 설정 (Office365 STARTTLS)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@fnfcorp.com
SMTP_PASSWORD=your_password
ALERT_RECIPIENTS=adult1@fnfcorp.com,adult2@fnfcorp.com           # 성인 수신자 (캠페인명 M으로 시작)
ALERT_RECIPIENTS_KIDS=kids1@fnfcorp.com,kids2@fnfcorp.com        # 키즈 수신자 (캠페인명 I로 시작)

# Slack Webhook (MLB 성인: 캠페인명 M으로 시작 / MLB 키즈: I로 시작)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...       # 성인 채널
SLACK_WEBHOOK_URL_KIDS=https://hooks.slack.com/services/...  # 키즈 채널
